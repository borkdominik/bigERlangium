{
  "name": "entity-relationship",
  "scopeName": "source.entity-relationship",
  "fileTypes": [
    ".er",
    ".erd"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
			"name": "constant.language.erdiagram",
			"match": "\\b(erdiagram)\\b"
		},
    {
      "name": "storage.type.erdiagram",
      "match": "\\b(notation)\\b"
    },
    {
      "name": "storage.modifier.erdiagram",
      "match": "\\b(default|bachman|crowsfoot|chen|uml)\\b"
    },
    {
			"name": "entity.name.type.erdiagram",
			"match": "\\b(entity|rel)\\b"
		},
    {
      "name": "keyword.entity-relationship",
      "match": "\\->|\\B(-o)\\b|\\b(o-)\\B|\\B(-\\*)\\B|\\B(\\*-)\\B"
    },
    {
      "name": "keyword.control.entity-relationship",
      "match": "\\b(1|0\\.\\.N|1\\.\\.N|N|NONE)\\b"
    },
    {
      "name": "entity.name.tag.entity-relationship",
      "match": "\\b(extends|weak)\\b"
    },
    {
      "name": "storage.modifier.entity-relationship",
      "match": "\\+|\\#|\\~|\\-(?!>)|\\b(public|private|protected|package|none)\\b"
    },
    {
			"name": "entity.other.attribute-name.entity-relationship",
			"match": "\\b(key|derived|multivalued|optional|partial-key)\\b"
		},
    {
      "name": "string.quoted.double.entity-relationship",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    },
    {
      "name": "string.quoted.single.entity-relationship",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.entity-relationship",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.entity-relationship"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.entity-relationship"
            }
          }
        },
        {
          "begin": "//",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.entity-relationship"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.entity-relationship"
        }
      ]
    },
    "string-character-escape": {
      "name": "constant.character.escape.entity-relationship",
      "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
    }
  }
}
